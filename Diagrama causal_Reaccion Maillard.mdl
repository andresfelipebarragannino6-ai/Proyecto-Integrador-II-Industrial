{UTF-8}
Aminoacidos= INTEG (Flujo P A+Formacion D-Consumo A1-Consumo A2,
		0)
	~	Minute
	~		|

Azucares=INTEG(-Consumo S,1)
	~	
	~		|

Consumo A1=k1*(Aminoacidos^n1)*(Azucares^m1)
	~	Minute
	~		|

Consumo A2=k2*(Aminoacidos^n2)*(Dicarbonilos^m2)
	~	Minute
	~		|

Consumo S=k1*(Aminoacidos^n1)*(Azucares^m1)
	~	Minute
	~		|

Degradacion D=kd*Dicarbonilos
	~	Minute
	~		|

Dicarbonilos= INTEG (Formacion D+Formacion M-Degradacion D,
		0)
	~	Minute
	~		|

Flujo P A=kp*Proteina
	~	Minute
	~		|

Formacion D=k1*(Aminoacidos^n1)*(Azucares^m1)
	~	Minute
	~		|

Formacion M=k2*(Aminoacidos^n2)*(Dicarbonilos^m2)
	~	Minute
	~		|

k1=0.05
	~	
	~		|

k2=0.03
	~	
	~		|

kd=0.02
	~	
	~		|

kp=0.08
	~	
	~		|

m1=1
	~	
	~		|

m2=1
	~	
	~		|

Melanoidinas=INTEG(Formacion M,0)
	~	Minute
	~		|

n1=1
	~	
	~		|

n2=1
	~	
	~		|

Proteina=INTEG(-Flujo P A,1)
	~	Minute
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

